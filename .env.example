# Site URL (used for canonical URLs, Open Graph, sitemap)
NEXT_PUBLIC_SITE_URL=https://kreona.pl

# Optional: Google Search Console verification
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Admin panel (/admin)
ADMIN_USERNAME=admin
ADMIN_PASSWORD="KreonaAdmin2026!"
ADMIN_SESSION_SECRET=change-me-long-random-string

# SQLite database (default: data/kreona.db). Needs a writable disk (VPS).
# DATABASE_PATH=/var/lib/kreona/kreona.db

# Resend — contact form emails
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Kreona <info@your-verified-domain.com>
# Fallback recipients (used once if admin settings are empty). Manage list in /admin/settings
EMAIL_TO=kreonapl@gmail.com
